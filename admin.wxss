.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.header {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.share-btn {
  display: block;
  margin: 20rpx auto 0;
  background: #1890ff;
  color: white;
  font-size: 26rpx;
  padding: 10rpx 30rpx;
  border-radius: 20rpx;
  border: none;
  line-height: 1.5;
  width: fit-content;
}

.today-stats {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  padding: 30rpx;
  color: white;
}

.today-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-align: center;
}

.stats {
  display: flex;
  justify-content: space-around;
  margin-bottom: 20rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.stat-value.pending {
  color: #ffd93d;
}

.stat-value.completed {
  color: #6bff6b;
}

.stat-value.highlight {
  color: #ff6b6b;
}

.stat-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.date-display {
  text-align: center;
  font-size: 24rpx;
  opacity: 0.8;
}

.history-section {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-top: 30rpx;
}

.history-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #666;
  margin-bottom: 20rpx;
}

.date-picker {
  background: white;
  border: 2rpx solid #e8e8e8;
  border-radius: 8rpx;
  padding: 20rpx;
  text-align: center;
}

.picker-text {
  color: #333;
  font-size: 28rpx;
}

.history-stats {
  display: flex;
  justify-content: space-around;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #e8e8e8;
}

.history-stat {
  font-size: 28rpx;
  color: #666;
}

.filter-bar {
  display: flex;
  background: white;
  border-radius: 12rpx;
  padding: 10rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  font-size: 28rpx;
  color: #666;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.filter-item.active {
  background: #1890ff;
  color: white;
  font-weight: bold;
}

.order-list {
  padding-bottom: 40rpx;
}

.order-card {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.order-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.order-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.order-status {
  font-size: 28rpx;
  color: #ff9800;
  font-weight: bold;
}

.order-status.completed {
  color: #4caf50;
}

.order-info {
  margin-bottom: 20rpx;
}

.info-row {
  display: flex;
  margin-bottom: 16rpx;
  align-items: center;
}

.info-label {
  width: 180rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  word-break: break-all;
}

.info-value.phone {
  color: #1890ff;
  font-weight: bold;
}

.info-value.highlight {
  color: #ff5722;
  font-weight: bold;
}

.info-value.small {
  font-size: 24rpx;
  color: #999;
}

.phone-call {
  margin-left: 20rpx;
  font-size: 32rpx;
  cursor: pointer;
}

.order-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  padding: 0;
}

.btn-deliver {
  background: #4caf50;
  color: white;
}

.btn-delete {
  background: #ff5722;
  color: white;
}

.empty {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}

.empty-text {
  font-size: 28rpx;
}
